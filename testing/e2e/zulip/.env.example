# Zulip E2E Test Configuration
# Copy this file to .env and fill in your values
SHOUTRRR_ZULIP_HOST=your-zulip-server.example.com
SHOUTRRR_ZULIP_BOT_MAIL=bot@your-zulip-server.example.com
SHOUTRRR_ZULIP_BOT_KEY=your-bot-api-key
SHOUTRRR_ZULIP_STREAM=general
SHOUTRRR_ZULIP_TOPIC=e2e-testing
# For direct message E2E tests (optional; falls back to SHOUTRRR_ZULIP_BOT_MAIL for self-DM).
# Value must be valid email(s) or numeric user ID(s) that exist on the target server.
SHOUTRRR_ZULIP_DM_TO=user1@example.com,user2@example.com
SHOUTRRR_ZULIP_READ_BY_SENDER=true
